{
  "Paths": {
    "DocsRoot": "docs",
    "SpecsRoot": "specs",
    "ArchitectureDir": "specs/architecture",
    "WorkItemsSpecsDir": "specs/work-items",
    "GeneratedDir": "specs/generated",
    "SpecsTemplatesDir": "specs/templates",
    "SpecsSchemasDir": "specs/schemas",
    "WorkRoot": "specs/work-items",
    "ItemsDir": "specs/work-items/quic"
  },
  "Ids": {
    "Width": 4
  },
  "Git": {
    "BranchPattern": "work/{id}-{slug}",
    "CommitMessagePattern": "Promote {id}: {title}",
    "DefaultBaseBranch": "main",
    "RequireCleanWorkingTree": false
  },
  "Github": {
    "Provider": "octokit",
    "DefaultDraft": false,
    "Host": "github.com",
    "Owner": "incursa",
    "Repository": "quic-dotnet",
    "Sync": {
      "Mode": "generate",
      "ConflictDefault": "fail",
      "ScheduleEnabled": false
    }
  },
  "Validation": {
    "LinkExclude": [
      ".artifacts/interop-autopilot/",
      ".dotnet-home/",
      "artifacts/spec-trace-migration/backups/",
      "artifacts/spec-trace-json-migration/backups/",
      "specs/generated/",
      "specs_old/"
    ],
    "DocExclude": [
      ".artifacts/interop-autopilot/",
      ".dotnet-home/",
      "artifacts/spec-trace-migration/backups/",
      "artifacts/spec-trace-json-migration/backups/",
      "specs/generated/",
      "specs_old/"
    ]
  },
  "Tui": {
    "Theme": "powershell",
    "UseEmoji": false,
    "AutoRefreshSeconds": 60
  }
}
